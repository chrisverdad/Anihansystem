{
  "name": "anihan-backend",
  "version": "1.0.0",
  "description": "AniHan API (Express + mysql2) — database: MySQL/MariaDB via XAMPP or any MySQL host (see .env.example)",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/scripts/seed.ts",
    "import-demo-accounts": "tsx src/scripts/upsertDemoAccounts.ts",
    "check-db": "tsx src/scripts/checkDbBridge.ts",
    "import:sql": "tsx src/scripts/importAnihanSql.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.16.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
